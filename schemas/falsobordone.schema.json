{
  "$id": "falsobordone",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/Falsobordone",
  "description": "Record of a falsobordone in music document.",
  "$comment": "Move some defs to $def?",
  "readOnly": true,
  "definitions": {
    "Document": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "shelfbook": { "type": "string" },
        "category": { "enum": ["manuscript", "print"] },
        "links": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "shelfbook", "links"]
    },
    "Psalmtone": {
      "type": "object",
      "tonus": { "enum": ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "Peregrinus", "Other"] },
      "required": ["type", "tonus"]
    },
    "Falsobordone": {
      "type": "object",
      "properties": {
        "file": {
          "$comment": "TO DO: URI",
          "type": "string"
        },
        "titleInDocument": { "type": "string" },
        "layout": { "enum": ["choirbook", "partitura", "partbooks"] },
        "voices": { "type": "array", "items": { "$ref": "#/definitions/Voice" } },
        "analysis": {
          "type": "object",
          "properties": {
            "tonus": {
              "description": "Reference to a tonus definition.",
              "type": "string",
              "pattern": "#.+"
            },
            "cf": {
              "type": "object",
              "properties": {
                "voice": { "$ref": "#/definitions/VoiceID" },
                "recit_pitch": { "$ref": "#/definitions/RecitPitch" },
                "final_pitch": { "$ref": "#/definitions/PitchID" },
                "intonatio": { "type": "boolean" }
              },
              "required": ["voice", "tonus", "recit_pitch", "final_pitch", "intonatio"]
            },
            "bass": {
              "description": "Structural bass notes.",
              "type": "object",
              "properties": {
                "recit_pitch": { "$ref": "#/definitions/RecitPitch" },
                "final_pitch": { "$ref": "#/definitions/PitchID" },
                "intonatio": { "type": "boolean" }
              },
              "required": ["recit_pitch", "final_pitch", "intonatio"]
            }
          },
          "required": ["tonus", "cf", "bass"]
        }
      },
      "required": ["file", "titleInDocument", "layout", "voices", "analysis"]
    },
    "Voice": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/definitions/VoiceID" },
        "document": {
          "description": "Reference to a document definition.",
          "type": "string",
          "pattern": "#.+"
        },
        "nameInDocument": { "type": "string" },
        "folio": {
          "type": "string",
          "pattenrn": "\\d+(v?-\\d+v?)?(, \\d+(v?-\\d+v?)?)*"
        },
        "link": { "type": "string" }
      },
      "required": ["id", "document", "nameInDocument", "folio", "link"]
    },

    "VoiceID": { "enum": ["cantus", "altus", "tenor", "bassus"] },

    "PitchID": { "enum": ["C", "D", "E", "F", "G", "A", "B", "Bb"] },
    "RecitPitch": {
      "description": "Written pitch of the reciting tone.",
      "$ref": "#/definitions/PitchID"
    }
  }
}
